generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String   @id @default(cuid())
  name        String
  pinHash     String   @default("")
  avatarColor String   @default("#22c55e")
  avatarUrl   String?
  /** yyyy-MM-dd — first calendar day calorie & weight logging are allowed again; null = off */
  vacationResumeDate String?
  /// IANA timezone (e.g. "America/New_York"); used to fire local-time reminders.
  timeZone    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  calorieEntries  CalorieEntry[]
  stepEntries     StepEntry[]
  runEntries      RunEntry[]
  workoutEntries  WorkoutEntry[]
  workoutTemplates WorkoutTemplate[]
  workoutSessions WorkoutSession[]
  sleepEntries    SleepEntry[]
  goals           Goal[]
  longGoals       LongGoal[]
  habits          Habit[]
  savedMeals      SavedMeal[]
  alcoholEntries  AlcoholEntry[]
  bowelEntries    BowelEntry[]
  journalEntries  JournalEntry[]
  recoveryDailyEntries RecoveryDailyEntry[]
  injuryRecords        InjuryRecord[]
  treatmentLogs        TreatmentLog[]
  coachConversations   CoachConversation[]
  coachMessages        CoachMessage[]
  pushSubscriptions       PushSubscription[]
  notificationPreferences NotificationPreference[]
  notificationLogs        NotificationLog[]
  fastingProfile          FastingProfile?
}

model CalorieEntry {
  id          String   @id @default(cuid())
  date        DateTime
  mealType    String
  description String?
  calories    Int
  protein     Float?
  carbs       Float?
  fat         Float?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model StepEntry {
  id        String   @id @default(cuid())
  date      DateTime
  count     Int
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model RunEntry {
  id          String   @id @default(cuid())
  date        DateTime
  distance    Float
  duration    Int
  environment String   @default("outdoor")
  notes       String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model WorkoutEntry {
  id        String   @id @default(cuid())
  date      DateTime
  type      String
  name      String
  duration  Int?
  notes     String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model WorkoutTemplate {
  id             String   @id @default(cuid())
  name           String
  exercises      String   @default("[]")
  tags           String   @default("[]")
  coverImageUrl  String?
  sortOrder      Int      @default(0)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())

  @@index([userId])
}

model WorkoutSession {
  id             String    @id @default(cuid())
  name           String
  date           DateTime
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  duration       Int?
  notes          String?
  status         String    @default("active")
  exercises      String    @default("[]")
  bodyWeightLb   Float?
  coverImageUrl  String?
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())

  @@index([date])
  @@index([status])
  @@index([userId])
}

model SleepEntry {
  id        String   @id @default(cuid())
  date      DateTime
  bedtime   DateTime
  wakeTime  DateTime
  quality   Int
  notes     String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model Goal {
  id        String    @id @default(cuid())
  category  String
  goalType  String    @default("daily")
  direction String    @default("up")
  target    Float
  unit      String
  deadline  DateTime?
  active    Boolean   @default(true)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@index([category])
  @@index([userId])
}

model LongGoal {
  id         String          @id @default(cuid())
  name       String
  category   String
  target     Float
  unit       String
  direction  String          @default("up")
  startValue Float?
  active     Boolean         @default(true)
  userId     String?
  user       User?           @relation(fields: [userId], references: [id])
  createdAt  DateTime        @default(now())
  entries    LongGoalEntry[]

  @@index([userId])
}

model LongGoalEntry {
  id        String   @id @default(cuid())
  goalId    String
  goal      LongGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  date      DateTime
  value     Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([goalId])
  @@index([date])
}

model Habit {
  id          String            @id @default(cuid())
  name        String
  icon        String            @default("check")
  color       String            @default("#22c55e")
  frequency   String            @default("daily")
  archived    Boolean           @default(false)
  sortOrder   Int               @default(0)
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())
  completions HabitCompletion[]

  @@index([userId])
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model SavedMeal {
  id        String   @id @default(cuid())
  name      String
  /// One tag, or comma-separated tags: breakfast, lunch, dinner, snack
  mealType  String
  calories  Int
  protein   Float?
  carbs     Float?
  fat       Float?
  useCount  Int      @default(0)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([mealType])
  @@index([userId])
}

model AlcoholEntry {
  id        String   @id @default(cuid())
  date      DateTime
  drinkType String
  quantity  Float
  units     Float
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model BowelEntry {
  id           String   @id @default(cuid())
  date         DateTime
  time         DateTime
  bristolScale Int
  notes        String?
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([userId])
}

model JournalEntry {
  id            String   @id @default(cuid())
  date          DateTime
  content       String   @default("")
  mood          Int?
  images        String   @default("[]")
  attachedStats String   @default("{}")
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([userId])
}

/// One row per calendar day per user: subjective recovery metrics (1–10 scales).
model RecoveryDailyEntry {
  id         String   @id @default(cuid())
  date       DateTime
  /// Higher = more pain
  pain       Int      @default(5)
  energy     Int      @default(5)
  mood       Int      @default(5)
  /// Higher = more muscle/joint soreness
  soreness   Int      @default(5)
  stress     Int      @default(5)
  mobility   Int      @default(5)
  /// Subjective “how rested / sleep quality feels today”
  sleepFeel  Int      @default(5)
  /// JSON array: { "key": interactionKey, "score": 1–10 } per muscle segment (DOMS).
  domsJson   String   @default("[]")
  notes      String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model InjuryRecord {
  id           String         @id @default(cuid())
  /// Key from recovery catalog or "custom"
  conditionKey String
  customLabel  String?
  /// "injury" | "illness"
  kind         String         @default("injury")
  bodyRegion   String?
  /// JSON string[] of body segment interaction keys (same format as DOMS); empty = infer from bodyRegion / catalog.
  bodySegmentKeysJson String @default("[]")
  onsetDate    DateTime
  resolvedAt   DateTime?
  /// mild | moderate | severe
  severity     String         @default("mild")
  /// active | improving | recovered
  status       String         @default("active")
  notes        String?
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  treatments   TreatmentLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}

model TreatmentLog {
  id           String       @id @default(cuid())
  injuryId     String
  injury       InjuryRecord @relation(fields: [injuryId], references: [id], onDelete: Cascade)
  date         DateTime
  /// Key from treatment catalog
  treatmentKey String
  notes        String?
  completed    Boolean      @default(true)
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  createdAt    DateTime     @default(now())

  @@index([injuryId])
  @@index([date])
  @@index([userId])
}

/// AI Coach chat thread, one row per conversation.
model CoachConversation {
  id             String         @id @default(cuid())
  title          String         @default("New chat")
  /// Picker key from src/lib/coach/models.ts (null = use account default)
  defaultModelId String?
  userId         String?
  user           User?          @relation(fields: [userId], references: [id])
  messages       CoachMessage[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId, updatedAt])
}

/// AI Coach message belonging to a conversation. `role` is "user" | "assistant" | "system".
model CoachMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// "user" | "assistant" | "system"
  role           String
  content        String            @default("")
  /// JSON array of attachments: [{ kind: "image", path, mime, name? }]
  attachmentsJson String           @default("[]")
  /// Coach model picker key for assistant turns (null for user/system messages).
  modelId        String?
  tokensIn       Int               @default(0)
  tokensOut      Int               @default(0)
  /// Optional userId denormalised from the conversation for fast per-user usage queries.
  userId         String?
  user           User?             @relation(fields: [userId], references: [id])
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

/// One row per (user, device). Stores the Web Push subscription that the browser created
/// after PushManager.subscribe(). We push to every active subscription for a user.
model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Globally unique endpoint URL issued by the push service (FCM, APNs gateway, Mozilla, …)
  endpoint    String   @unique
  /// Client public key for envelope encryption (RFC 8291).
  p256dh      String
  /// 16-byte HKDF auth secret.
  auth        String
  /// User agent string at subscription time — used to render a friendly device label.
  userAgent   String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([userId])
}

/// Per-user, per-notification-type toggles and (for scheduled reminders) a local time-of-day.
/// `type` matches a key from src/lib/notifications/catalog.ts.
model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  enabled   Boolean  @default(true)
  /// HH:mm in the user's local time; null for event-driven types.
  timeOfDay String?
  /// JSON for per-type extras (e.g. specific habit ids opted in).
  metaJson  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

/// Idempotency log so the 5-minute cron never sends the same daily reminder twice.
/// `fireDay` is yyyy-MM-dd in the user's local timezone.
model NotificationLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  fireDay      String
  successCount Int      @default(0)
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([userId, type, fireDay])
  @@index([userId, createdAt])
}

/// Server-side mirror of the client's fasting configuration so the cron can fire
/// "fasting complete" / "eating window closing" notifications even when the app is closed.
model FastingProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fastHours             Int      @default(16)
  eatHours              Int      @default(8)
  /// Epoch ms when the eating window last ended (anchor for anchored mode). Null = clock mode.
  lastMealAtMs          BigInt?
  /// "anchored" | "clock"
  mode                  String   @default("anchored")
  /// Minutes from local midnight when the eating window opens (clock mode only).
  eatWindowStartMinutes Int      @default(720)
  updatedAt             DateTime @updatedAt
}
