generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CalorieEntry {
  id          String   @id @default(cuid())
  date        DateTime
  mealType    String
  description String?
  calories    Int
  protein     Float?
  carbs       Float?
  fat         Float?
  createdAt   DateTime @default(now())

  @@index([date])
}

model StepEntry {
  id        String   @id @default(cuid())
  date      DateTime
  count     Int
  createdAt DateTime @default(now())

  @@index([date])
}

model RunEntry {
  id          String   @id @default(cuid())
  date        DateTime
  distance    Float
  duration    Int
  environment String   @default("outdoor")
  notes       String?
  createdAt   DateTime @default(now())

  @@index([date])
}

model WorkoutEntry {
  id        String   @id @default(cuid())
  date      DateTime
  type      String
  name      String
  duration  Int?
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
}

model WorkoutTemplate {
  id        String   @id @default(cuid())
  name      String
  exercises String   @default("[]")
  createdAt DateTime @default(now())
}

model WorkoutSession {
  id         String    @id @default(cuid())
  name       String
  date       DateTime
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  duration   Int?
  notes      String?
  status     String    @default("active")
  exercises  String    @default("[]")
  createdAt  DateTime  @default(now())

  @@index([date])
  @@index([status])
}

model SleepEntry {
  id        String   @id @default(cuid())
  date      DateTime
  bedtime   DateTime
  wakeTime  DateTime
  quality   Int
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
}

model Goal {
  id        String    @id @default(cuid())
  category  String
  goalType  String    @default("daily")
  direction String    @default("up")
  target    Float
  unit      String
  deadline  DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([category])
}

model LongGoal {
  id         String          @id @default(cuid())
  name       String
  category   String
  target     Float
  unit       String
  direction  String          @default("up")
  startValue Float?
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  entries    LongGoalEntry[]
}

model LongGoalEntry {
  id        String   @id @default(cuid())
  goalId    String
  goal      LongGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  date      DateTime
  value     Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([goalId])
  @@index([date])
}

model Habit {
  id          String            @id @default(cuid())
  name        String
  icon        String            @default("check")
  color       String            @default("#22c55e")
  frequency   String            @default("daily")
  archived    Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  completions HabitCompletion[]
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model SavedMeal {
  id        String   @id @default(cuid())
  name      String
  mealType  String
  calories  Int
  protein   Float?
  carbs     Float?
  fat       Float?
  useCount  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([mealType])
}

model AlcoholEntry {
  id        String   @id @default(cuid())
  date      DateTime
  drinkType String
  quantity  Float
  units     Float
  createdAt DateTime @default(now())

  @@index([date])
}

model BowelEntry {
  id           String   @id @default(cuid())
  date         DateTime
  time         DateTime
  bristolScale Int
  notes        String?
  createdAt    DateTime @default(now())

  @@index([date])
}

model JournalEntry {
  id            String   @id @default(cuid())
  date          DateTime
  content       String   @default("")
  mood          Int?
  images        String   @default("[]")
  attachedStats String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}
